+static void test_exitless_error_cases(void)
+{
+	struct kvm_apf_eventfd evtfd_args = {};
+	struct kvm_vcpu *vcpu;
+	struct kvm_run *run;
+	struct kvm_vm *vm;
+	int notify_fd, complete_fd;
+	int r;
+
+	pr_info("Testing KVM_SET_APF_EVENTFD error cases\n");
+
+	vm = create_apf_test_vm(&vcpu);
+	run = vcpu->run;
+
+	notify_fd = eventfd(0, EFD_NONBLOCK);
+	TEST_ASSERT(notify_fd >= 0, "eventfd notify");
+	complete_fd = eventfd(0, EFD_NONBLOCK);
+	TEST_ASSERT(complete_fd >= 0, "eventfd complete");
+
+	evtfd_args.fd = notify_fd;
+	evtfd_args.complete_fd = complete_fd;
+	evtfd_args.flags = 1;
+	r = __vcpu_ioctl(vcpu, KVM_SET_APF_EVENTFD, &evtfd_args);
+	TEST_ASSERT(r == -1 && errno == EINVAL,
+		    "Expected EINVAL for non-zero eventfd flags");
+
+	memset(&evtfd_args, 0, sizeof(evtfd_args));
+	evtfd_args.fd = -2;
+	evtfd_args.complete_fd = complete_fd;
+	r = __vcpu_ioctl(vcpu, KVM_SET_APF_EVENTFD, &evtfd_args);
+	TEST_ASSERT(r == -1 && errno == EINVAL,
+		    "Expected EINVAL for invalid deregister fd");
+
+	memset(&evtfd_args, 0, sizeof(evtfd_args));
+	evtfd_args.fd = notify_fd;
+	evtfd_args.complete_fd = notify_fd;
+	r = __vcpu_ioctl(vcpu, KVM_SET_APF_EVENTFD, &evtfd_args);
+	TEST_ASSERT(r == -1 && errno == EINVAL,
+		    "Expected EINVAL for duplicate eventfd");
+
+	r = _vcpu_run(vcpu);
+	TEST_ASSERT(r != 0 && errno == EFAULT,
+		    "Expected EFAULT, got r=%d errno=%d", r, errno);
+	TEST_ASSERT_EQ(run->exit_reason, KVM_EXIT_MEMORY_FAULT);
+
+	if (!(run->memory_fault.flags & KVM_MEMORY_EXIT_FLAG_APF)) {
+		pr_info("  APF not created - skip EBUSY check\n");
+		goto done;
+	}
+
+	memset(&evtfd_args, 0, sizeof(evtfd_args));
+	evtfd_args.fd = notify_fd;
+	evtfd_args.complete_fd = complete_fd;
+	r = __vcpu_ioctl(vcpu, KVM_SET_APF_EVENTFD, &evtfd_args);
+	TEST_ASSERT(r == -1 && errno == EBUSY,
+		    "Expected EBUSY with pending APF");
+
+done:
+	close(notify_fd);
+	close(complete_fd);
+	kvm_vm_free(vm);
+	pr_info("  PASSED\n");
+}
+
+/*
+ * Test: exitless APF via eventfd + shared ring buffer.
+ *
+ * With exitless APF, the vCPU doesn't exit to userspace. Instead, KVM
+ * writes to the notify ring, signals the notify eventfd, and auto-halts
+ * the vCPU. A handler thread polls the notify eventfd, resolves the page,
+ * writes to the completion ring, and signals the completion eventfd.
+ * KVM's workqueue then wakes the halted vCPU.
+ */
+struct exitless_ctx {
+	struct kvm_apf_shared_page *shared;
+	struct kvm_vm *vm;
+	int notify_fd;
+	int complete_fd;
+};
+
+static bool apf_ring_has_entry(struct kvm_apf_ring *ring,
+			       uint32_t *head, uint32_t *tail)
+{
+	/*
+	 * Indices are free-running u32; mask only when indexing entries.
+	 * Load head with acquire semantics to match the release store KVM
+	 * issued when publishing the ring entry.  Read tail with relaxed
+	 * semantics (we are the sole consumer).
+	 */
+	*head = __atomic_load_n(&ring->head, __ATOMIC_ACQUIRE);
+	*tail = __atomic_load_n(&ring->tail, __ATOMIC_RELAXED);
+
+	return *head != *tail;
+}
+
+static void *exitless_handler(void *arg)
+{
+	struct exitless_ctx *ctx = arg;
+	struct kvm_apf_ring *ring = &ctx->shared->notify;
+	struct kvm_apf_ring *comp = &ctx->shared->complete;
+	struct kvm_apf_ring_entry *entry;
+	uint32_t head, tail, comp_head;
+	uint64_t cnt;
+	ssize_t len;
+	void *mem;
+	int r;
+
+	for (;;) {
+		struct timeval tv = { .tv_sec = 5 };
+		fd_set rfds;
+
+		if (apf_ring_has_entry(ring, &head, &tail))
+			break;
+
+		__atomic_fetch_or(&ctx->shared->header.flags,
+				  KVM_APF_SHARED_FLAG_NOTIFY_ARMED,
+				  __ATOMIC_RELEASE);
+		/* Paired with KVM's full barrier before testing NOTIFY_ARMED. */
+		__atomic_thread_fence(__ATOMIC_SEQ_CST);
+
+		if (apf_ring_has_entry(ring, &head, &tail)) {
+			__atomic_fetch_and(&ctx->shared->header.flags,
+					   ~KVM_APF_SHARED_FLAG_NOTIFY_ARMED,
+					   __ATOMIC_ACQ_REL);
+			break;
+		}
+
+		FD_ZERO(&rfds);
+		FD_SET(ctx->notify_fd, &rfds);
+		r = select(ctx->notify_fd + 1, &rfds, NULL, NULL, &tv);
+		if (r <= 0)
+			return NULL;
+
+		len = read(ctx->notify_fd, &cnt, sizeof(cnt));
+		TEST_ASSERT_EQ(len, sizeof(cnt));
+	}
+
+	entry = &ring->entries[tail & (KVM_APF_RING_SIZE - 1)];
+	pr_info("  Ring entry: gpa=%#llx flags=%#llx\n",
+		entry->gpa, entry->flags);
+	TEST_ASSERT_EQ(entry->gpa, TEST_GPA);
+
+	/* Advance tail with release semantics. */
+	__atomic_store_n(&ring->tail, tail + 1, __ATOMIC_RELEASE);
+
+	mem = addr_gpa2hva(ctx->vm, TEST_GPA);
+	memset(mem, 0, PAGE_SIZE);
+	clear_userfault_memslot(ctx->vm);
+
+	comp_head = comp->head;
+	comp->entries[comp_head & (KVM_APF_RING_SIZE - 1)].gpa = TEST_GPA;
+	comp->entries[comp_head & (KVM_APF_RING_SIZE - 1)].flags = 0;
+	__atomic_store_n(&comp->head, comp_head + 1, __ATOMIC_RELEASE);
+
+	cnt = 1;
+	len = write(ctx->complete_fd, &cnt, sizeof(cnt));
+	TEST_ASSERT_EQ(len, sizeof(cnt));
+
+	return (void *)1;
+}
+
+static void test_watchdog_expired(int sig)
+{
+	TEST_FAIL("exitless test watchdog fired after %d seconds; vCPU stuck",
+		  TEST_WATCHDOG_SECS);
+}
+
+static void test_exitless_eventfd(void)
+{
+	struct kvm_apf_eventfd evtfd_args = {};
+	struct exitless_ctx ctx;
+	struct kvm_apf_shared_page *shared;
+	struct kvm_vcpu *vcpu;
+	struct kvm_vm *vm;
+	pthread_t handler;
+	void *handler_ret;
+	void *shared_mem;
+	int notify_fd, complete_fd;
+	int r;
+
+	pr_info("Testing exitless APF via eventfd\n");
+
+	vm = create_apf_test_vm(&vcpu);
+
+	notify_fd = eventfd(0, EFD_NONBLOCK);
+	TEST_ASSERT(notify_fd >= 0, "eventfd notify");
+	complete_fd = eventfd(0, EFD_NONBLOCK);
+	TEST_ASSERT(complete_fd >= 0, "eventfd complete");
+
+	evtfd_args.fd = notify_fd;
+	evtfd_args.complete_fd = complete_fd;
+	vcpu_ioctl(vcpu, KVM_SET_APF_EVENTFD, &evtfd_args);
+
+	shared_mem = mmap(NULL, PAGE_SIZE, PROT_READ | PROT_WRITE,
+			  MAP_SHARED, vcpu->fd,
+			  KVM_APF_PAGE_OFFSET * getpagesize());
+	TEST_ASSERT(shared_mem != MAP_FAILED, "mmap APF page");
+	shared = shared_mem;
+	TEST_ASSERT_EQ(shared->header.version, KVM_APF_SHARED_VERSION);
+	TEST_ASSERT_EQ(shared->header.ring_size, KVM_APF_RING_SIZE);
+	TEST_ASSERT_EQ(shared->header.entry_size,
+		       sizeof(struct kvm_apf_ring_entry));
+
+	ctx = (struct exitless_ctx) {
+		.shared = shared,
+		.vm = vm,
+		.notify_fd = notify_fd,
+		.complete_fd = complete_fd,
+	};
+	r = pthread_create(&handler, NULL, exitless_handler, &ctx);
+	TEST_ASSERT(!r, "pthread_create failed, r=%d", r);
+
+	signal(SIGALRM, test_watchdog_expired);
+	alarm(TEST_WATCHDOG_SECS);
+
+	vcpu_run(vcpu);
+	TEST_ASSERT_EQ(get_ucall(vcpu, NULL), UCALL_DONE);
+
+	alarm(0);
+	signal(SIGALRM, SIG_DFL);
+
+	pthread_join(handler, &handler_ret);
+	TEST_ASSERT(handler_ret, "Handler thread should have fired");
+
+	memset(&evtfd_args, 0, sizeof(evtfd_args));
+	evtfd_args.fd = -1;
+	vcpu_ioctl(vcpu, KVM_SET_APF_EVENTFD, &evtfd_args);
+
+	close(notify_fd);
+	close(complete_fd);
+	munmap(shared_mem, PAGE_SIZE);
+	kvm_vm_free(vm);
+	pr_info("  PASSED\n");
+}
+
 int main(int argc, char *argv[])
