@@ -6272,6 +6284,16 @@ long kvm_arch_vcpu_ioctl(struct file *filp,
 		}
 		break;
 	}
+	case KVM_SET_APF_EVENTFD: {
+		struct kvm_apf_eventfd args;
+
+		r = -EFAULT;
+		if (copy_from_user(&args, argp, sizeof(args)))
