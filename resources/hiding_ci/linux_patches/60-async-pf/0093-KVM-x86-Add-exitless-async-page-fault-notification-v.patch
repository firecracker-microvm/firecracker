 #include "async_pf.h"
 #include <trace/events/kvm.h>
 
 static struct kmem_cache *async_pf_cache;
 
+#ifdef CONFIG_KVM_ASYNC_PF_USERFAULT
+static void kvm_async_pf_complete_work(struct work_struct *work);
+
+static unsigned int async_pf_userfault_hash(gfn_t gfn)
+{
+	BUILD_BUG_ON(!is_power_of_2(ASYNC_PF_PER_VCPU));
+
+	return hash_64(gfn, order_base_2(ASYNC_PF_PER_VCPU));
+}
+
+static struct hlist_head *
+async_pf_userfault_hash_head(struct kvm_vcpu *vcpu, gfn_t gfn)
+{
+	return &vcpu->async_pf.userfault_hash[async_pf_userfault_hash(gfn)];
+}
+#endif /* CONFIG_KVM_ASYNC_PF_USERFAULT */
+
 int kvm_async_pf_init(void)
 {
 	async_pf_cache = KMEM_CACHE(kvm_async_pf, 0);
@@ -42,9 +63,114 @@ void kvm_async_pf_vcpu_init(struct kvm_vcpu *vcpu)
 	spin_lock_init(&vcpu->async_pf.lock);
 	atomic_set(&vcpu->async_pf.queued, 0);
 	vcpu->async_pf.clearing = false;
+
+#ifdef CONFIG_KVM_ASYNC_PF_USERFAULT
 	vcpu->async_pf.userfault_enabled = false;
+	vcpu->async_pf.userfault_hash = NULL;
+	vcpu->async_pf.userfault_pool = NULL;
+	INIT_LIST_HEAD(&vcpu->async_pf.userfault_free);
+	vcpu->async_pf.notify_head = 0;
+	vcpu->async_pf.notify_tail_cache = 0;
+	vcpu->async_pf.eventfd = NULL;
+	vcpu->async_pf.complete_eventfd = NULL;
+	vcpu->async_pf.shared_page = NULL;
+	/*
+	 * Initialize the completion work exactly once.  Re-initializing it on
+	 * each KVM_SET_APF_EVENTFD registration would race with a concurrent
+	 * schedule_work() from the previous registration's eventfd wakeup
+	 * callback and corrupt the workqueue.
+	 */
+	INIT_WORK(&vcpu->async_pf.complete_work, kvm_async_pf_complete_work);
+#endif
+}
+
+#ifdef CONFIG_KVM_ASYNC_PF_USERFAULT
+/*
+ * Called from KVM_ENABLE_CAP(KVM_CAP_ASYNC_PF_USERFAULT) under vcpu->mutex.
+ * The GFN lookup hash is allocated on first enable and freed only at vCPU
+ * destruction, so lookups never observe a transiently freed hash.
+ */
+int kvm_async_pf_userfault_enable(struct kvm_vcpu *vcpu, bool enable)
+{
+	struct hlist_head *hash;
+
+	if (enable && !vcpu->async_pf.userfault_hash) {
