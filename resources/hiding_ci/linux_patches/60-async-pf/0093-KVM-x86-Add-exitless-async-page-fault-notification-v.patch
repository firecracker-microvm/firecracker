+		ret = -ENOMEM;
+		goto err_eventfd;
+	}
+	shared = page_address(page);
+	shared->header.version = KVM_APF_SHARED_VERSION;
+	shared->header.ring_size = KVM_APF_RING_SIZE;
+	shared->header.entry_size = sizeof(struct kvm_apf_ring_entry);
+
+	userfault_pool = kcalloc(ASYNC_PF_PER_VCPU, sizeof(*userfault_pool),
+				 GFP_KERNEL_ACCOUNT);
+	if (!userfault_pool) {
+		ret = -ENOMEM;
+		goto err_page;
+	}
+
+	if (fd_empty(complete_f)) {
+		ret = -EBADF;
+		goto err_pool;
+	}
+
+	complete_eventfd = eventfd_ctx_fileget(fd_file(complete_f));
+	if (IS_ERR(complete_eventfd)) {
+		ret = PTR_ERR(complete_eventfd);
+		complete_eventfd = NULL;
+		goto err_pool;
+	}
+
+	if (eventfd == complete_eventfd) {
+		ret = -EINVAL;
+		goto err_complete;
+	}
+
+	apf_pt.vcpu = vcpu;
+	apf_pt.ret = 0;
+	init_poll_funcptr(&apf_pt.pt, kvm_async_pf_complete_register);
+
+	spin_lock(&vcpu->async_pf.lock);
+
+	if (atomic_read(&vcpu->async_pf.queued)) {
+		spin_unlock(&vcpu->async_pf.lock);
+		ret = -EBUSY;
+		goto err_complete;
+	}
+
+	/*
+	 * Tear down old exitless resources (drops and re-takes the lock).
+	 * This removes the old registration's wait-queue hook and flushes
+	 * complete_work, so it is safe to re-arm the (vcpu_init-initialized)
+	 * work for the new registration below.
+	 */
+	if (vcpu->async_pf.eventfd || vcpu->async_pf.complete_eventfd)
+		kvm_async_pf_teardown_exitless(vcpu);
+	old_userfault_pool = async_pf_detach_userfault_pool(vcpu);
+
+	WRITE_ONCE(vcpu->async_pf.complete_eventfd, complete_eventfd);
+
+	events = vfs_poll(fd_file(complete_f), &apf_pt.pt);
+	ret = apf_pt.ret;
+	if (ret) {
+		WRITE_ONCE(vcpu->async_pf.complete_eventfd, NULL);
+	} else {
+		async_pf_install_userfault_pool(vcpu, userfault_pool);
+		userfault_pool = NULL;
+		vcpu->async_pf.notify_head = 0;
+		vcpu->async_pf.notify_tail_cache = 0;
+		vcpu->async_pf.eventfd = eventfd;
+		vcpu->async_pf.shared_page = page;
+	}
+
+	spin_unlock(&vcpu->async_pf.lock);
+	kfree(old_userfault_pool);
+
+	if (ret)
+		goto err_complete;
+
+	if (events & EPOLLIN)
+		schedule_work(&vcpu->async_pf.complete_work);
+
+	return 0;
+
+err_complete:
+	eventfd_ctx_put(complete_eventfd);
+err_pool:
+	kfree(userfault_pool);
+err_page:
+	__free_page(page);
+err_eventfd:
+	eventfd_ctx_put(eventfd);
+	return ret;
+}
+
+static bool
+kvm_async_pf_test_and_clear_notify_armed(struct kvm_apf_shared_page *shared)
+{
+	u32 flags = READ_ONCE(shared->header.flags);
+
+	while (flags & KVM_APF_SHARED_FLAG_NOTIFY_ARMED) {
+		u32 new_flags = flags & ~KVM_APF_SHARED_FLAG_NOTIFY_ARMED;
+		u32 old_flags = cmpxchg(&shared->header.flags, flags, new_flags);
+
+		if (old_flags == flags)
+			return true;
+
+		flags = old_flags;
+	}
+
+	return false;
+}
+
+/*
+ * Create a userfault APF and, if an exitless eventfd is configured, write
+ * the fault into the notify ring and signal userspace if notification is
+ * armed.  Returns one of KVM_ASYNC_PF_SETUP_* (see kvm_host.h).
+ *
+ * Folding exists-check + enqueue + ring publish into one lock hold drops
+ * per-fault lock acquisitions from three to one, and also lets us assign
+ * uf_state on the work pointer directly (no second queue walk).
+ */
+int kvm_async_pf_setup_userfault(struct kvm_vcpu *vcpu, gpa_t cr2_or_gpa,
+				 unsigned long hva,
+				 struct kvm_arch_async_pf *arch,
+				 u64 exitless_flags)
+{
+	struct kvm_apf_shared_page *shared;
+	struct kvm_apf_ring *ring;
+	struct kvm_async_pf *work, *existing;
+	struct eventfd_ctx *eventfd;
+	u32 head, tail, idx;
+	gpa_t ring_gpa;
+	bool notify_armed;
+
+	if (unlikely(kvm_is_error_hva(hva)))
+		return KVM_ASYNC_PF_SETUP_FAILED;
+
+	if (unlikely(atomic_inc_return(&vcpu->async_pf.queued) > ASYNC_PF_PER_VCPU)) {
+		atomic_dec(&vcpu->async_pf.queued);
+		return KVM_ASYNC_PF_SETUP_FAILED;
+	}
+
+	spin_lock(&vcpu->async_pf.lock);
+
+	/*
+	 * The hash is allocated when KVM_CAP_ASYNC_PF_USERFAULT is enabled,
+	 * which is a prerequisite for reaching this point.
+	 */
+	if (WARN_ON_ONCE(!vcpu->async_pf.userfault_hash)) {
+		spin_unlock(&vcpu->async_pf.lock);
+		atomic_dec(&vcpu->async_pf.queued);
+		return KVM_ASYNC_PF_SETUP_FAILED;
+	}
+
+	existing = async_pf_find_userfault_from_gfn(vcpu, arch->gfn);
+	if (existing) {
+		spin_unlock(&vcpu->async_pf.lock);
+		atomic_dec(&vcpu->async_pf.queued);
+		return KVM_ASYNC_PF_SETUP_DUPLICATE;
+	}
+
+	work = async_pf_alloc_userfault_work(vcpu);
+	if (!work) {
+		spin_unlock(&vcpu->async_pf.lock);
+		work = kmem_cache_zalloc(async_pf_cache, GFP_NOWAIT | __GFP_NOWARN);
+		if (unlikely(!work)) {
+			atomic_dec(&vcpu->async_pf.queued);
+			return KVM_ASYNC_PF_SETUP_FAILED;
+		}
+
+		spin_lock(&vcpu->async_pf.lock);
+		existing = async_pf_find_userfault_from_gfn(vcpu, arch->gfn);
+		if (existing) {
+			spin_unlock(&vcpu->async_pf.lock);
+			kmem_cache_free(async_pf_cache, work);
+			atomic_dec(&vcpu->async_pf.queued);
+			return KVM_ASYNC_PF_SETUP_DUPLICATE;
+		}
+	}
+
+	work->wakeup_all = false;
+	work->vcpu = vcpu;
+	work->cr2_or_gpa = cr2_or_gpa;
+	work->addr = hva;
+	work->arch = *arch;
+	work->notpresent_injected = false;
+	work->userfault = true;
+	work->uf_state = KVM_APF_UF_PENDING;
+
+	list_add_tail(&work->queue, &vcpu->async_pf.queue);
+	hlist_add_head(&work->userfault_node,
+		       async_pf_userfault_hash_head(vcpu, work->arch.gfn));
+
+	eventfd = vcpu->async_pf.eventfd;
+	if (!eventfd || !vcpu->async_pf.shared_page) {
+		spin_unlock(&vcpu->async_pf.lock);
+		goto exit_to_userspace;
+	}
+
+	shared = page_address(vcpu->async_pf.shared_page);
+	ring = &shared->notify;
+
+	/*
+	 * KVM's notify_head is the authoritative producer index; the shared
+	 * ring's head is write-only from KVM's perspective so that userspace
+	 * corrupting it can only break its own consumption, never KVM's
+	 * bookkeeping.  notify_tail_cache avoids reading the consumer index
+	 * (and bouncing its cacheline) unless the ring looks full.
+	 */
+	head = vcpu->async_pf.notify_head;
+	tail = vcpu->async_pf.notify_tail_cache;
+
+	if (head - tail >= KVM_APF_RING_SIZE) {
+		/* Paired with userspace's release store after consuming entries. */
+		tail = smp_load_acquire(&ring->tail);
+		vcpu->async_pf.notify_tail_cache = tail;
+
+		if (head - tail >= KVM_APF_RING_SIZE) {
+			spin_unlock(&vcpu->async_pf.lock);
+			goto exit_to_userspace;
+		}
+	}
+
+	ring_gpa = (gpa_t)arch->gfn << PAGE_SHIFT;
+	idx = head & (KVM_APF_RING_SIZE - 1);
+	ring->entries[idx].gpa = ring_gpa;
+	ring->entries[idx].flags = exitless_flags;
+	vcpu->async_pf.notify_head = head + 1;
+	/* Publish the notification entry before advancing head. */
+	smp_store_release(&ring->head, head + 1);
+	/*
+	 * Paired with userspace's full barrier after arming notification: ensure
+	 * the head update is visible before deciding whether a wakeup is needed.
+	 */
+	smp_mb();
+	notify_armed = kvm_async_pf_test_and_clear_notify_armed(shared);
+
+	/*
+	 * Set ACCEPTED directly on the work pointer: the exitless path
+	 * auto-accepts on userspace's behalf, so there is no ACCEPT ioctl
+	 * to follow and no need for a second queue walk.
+	 */
+	work->uf_state = KVM_APF_UF_ACCEPTED;
+
+	spin_unlock(&vcpu->async_pf.lock);
+
+	/*
+	 * See kvm_setup_async_pf() for the notpresent_injected invariant:
+	 * the work item is only freed on the same vCPU thread, so running
+	 * this outside the spinlock is safe.
+	 */
+	work->notpresent_injected = kvm_arch_async_page_not_present(vcpu, work);
+
+	/*
+	 * Safe to touch the eventfd without a refcount here because the
+	 * eventfd is only released by kvm_async_pf_teardown_exitless(), which
+	 * runs on the vCPU thread (KVM_SET_APF_EVENTFD under vcpu->mutex, or
+	 * kvm_async_pf_vcpu_destroy() when no vCPU ioctls can be in flight).
+	 */
+	if (notify_armed)
+		eventfd_signal(eventfd);
+
+	trace_kvm_async_pf_exitless_notify(vcpu->vcpu_id, ring_gpa);
+
+	return KVM_ASYNC_PF_SETUP_EXITLESS;
+
+exit_to_userspace:
+	work->notpresent_injected = kvm_arch_async_page_not_present(vcpu, work);
+	return KVM_ASYNC_PF_SETUP_EXIT;
+}
+#endif /* CONFIG_KVM_ASYNC_PF_USERFAULT */
