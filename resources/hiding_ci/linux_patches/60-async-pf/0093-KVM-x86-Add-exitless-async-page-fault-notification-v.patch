+		apf->uf_state = KVM_APF_UF_COMPLETED;
+		completed = true;
+		if (list_empty(&vcpu->async_pf.done))
+			first_add = true;
+		list_add_tail(&apf->link, &vcpu->async_pf.done);
+	}
