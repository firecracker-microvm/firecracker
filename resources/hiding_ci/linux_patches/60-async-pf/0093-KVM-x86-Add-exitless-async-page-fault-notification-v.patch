diff --git a/include/uapi/linux/kvm.h b/include/uapi/linux/kvm.h
index 6ccd393c58cd..b47915980fa6 100644
--- a/include/uapi/linux/kvm.h
+++ b/include/uapi/linux/kvm.h
@@ -1655,6 +1655,70 @@ struct kvm_async_pf_req {
 	__u64 reserved[2];
 };
 
+/*
+ * KVM_SET_APF_EVENTFD - Register eventfds for exitless async page fault
+ * notification.  When set, userfault APFs write APF details to a
+ * kernel-allocated shared page instead of exiting to userspace.  KVM
+ * signals the notification eventfd only when userspace has armed it via
+ * the shared page.  Userspace maps the shared page via mmap(vcpu_fd) at
+ * offset
+ * KVM_APF_PAGE_OFFSET * PAGE_SIZE.  Layout of the shared page is
+ * struct kvm_apf_shared_page (see below).
+ *
+ * fd = -1 to deregister.
+ *
+ * `flags` is currently unused and must be zero.  New flag bits will be
+ * allocated from the LSB; userspace must pass 0 for forwards compatibility
+ * until kernel support is checked via KVM_CHECK_EXTENSION.
+ */
+#define KVM_SET_APF_EVENTFD	_IOW(KVMIO, 0xd9, struct kvm_apf_eventfd)
+
+struct kvm_apf_eventfd {
+	__s32 fd;
+	__s32 complete_fd;
+	__u32 flags;
+	__u32 padding;
+	__u64 reserved[2];
+};
+
+/*
+ * Shared page for exitless APF, containing both notification and completion
+ * ring buffers.
+ *
+ * Notification ring (notify): kernel writes head, userspace writes tail.
+ * Completion ring (complete): userspace writes head, kernel writes tail.
+ */
+#define KVM_APF_SHARED_VERSION		1
+#define KVM_APF_RING_SIZE	64
+#define KVM_APF_SHARED_FLAG_NOTIFY_ARMED	_BITUL(0)
+
+struct kvm_apf_shared_header {
+	__u32 version;
+	__u32 ring_size;
+	__u32 entry_size;
+	__u32 flags;
+	__u64 reserved[6];
+};
+
+struct kvm_apf_ring_entry {
+	__u64 gpa;
+	__u64 flags;
+};
+
+struct kvm_apf_ring {
+	__u32 head;
+	__u32 _pad_head[15];
+	__u32 tail;
+	__u32 _pad_tail[15];
+	struct kvm_apf_ring_entry entries[KVM_APF_RING_SIZE];
+};
+
+struct kvm_apf_shared_page {
+	struct kvm_apf_shared_header header;
+	struct kvm_apf_ring notify;
+	struct kvm_apf_ring complete;
+};
+
 struct kvm_pre_fault_memory {
 	__u64 gpa;
 	__u64 size;
