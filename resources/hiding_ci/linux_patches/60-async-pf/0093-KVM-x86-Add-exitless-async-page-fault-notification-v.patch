+/*
+ * Exitless APF support - signal eventfd instead of exiting to userspace.
+ *
+ * The shared page is allocated by the kernel and mmap'd by userspace via
+ * the vCPU fd at offset KVM_APF_PAGE_OFFSET * PAGE_SIZE.  This avoids
+ * FOLL_LONGTERM-pinning a userspace anon page.
+ *
+ * Wakeups on the completion eventfd are delivered via an exclusive
+ * priority wait queue entry (see kvm_async_pf_complete_register()): a
+ * workqueue poll of the eventfd would also work, but the wait-queue hook
+ * is how irqfd/ioeventfd dispatch works in KVM and keeps wakeup latency
+ * to the bare minimum (schedule a kthread, no intermediate poll loop).
+ */
+bool kvm_async_pf_drain_exitless(struct kvm_vcpu *vcpu)
+{
+	struct kvm_apf_shared_page *shared;
+	struct kvm_apf_ring *ring;
+	bool first_add = false;
+	bool completed = false;
+	bool clearing;
+	bool more = false;
+	u32 head, start, tail;
+
+	/*
+	 * Cheap lockless check so that vCPUs without an exitless registration
+	 * (e.g. the legacy APF-halt path) don't take the lock for nothing.
+	 * The pointer is only published/cleared under the lock, which is
+	 * re-checked below.
+	 */
+	if (!READ_ONCE(vcpu->async_pf.shared_page))
+		return false;
+
+	spin_lock(&vcpu->async_pf.lock);
+	if (!vcpu->async_pf.shared_page) {
+		spin_unlock(&vcpu->async_pf.lock);
+		return false;
+	}
+	shared = page_address(vcpu->async_pf.shared_page);
+	ring = &shared->complete;
+
+	/*
+	 * ->clearing is constant for the duration of the critical section (it
+	 * is only written under the lock).  If the vCPU is cancelling its APF
+	 * queue (PV async-PF MSR disable, CR0.PG toggle, INIT), still consume
+	 * ring entries so userspace's producer index keeps advancing, but
+	 * don't complete anything: the APFs are being cancelled.
+	 */
+	clearing = vcpu->async_pf.clearing;
+
+	/*
+	 * Drain the whole ring under a single lock: inline the completion
+	 * logic (no drop-and-reacquire per entry) and issue a single wake at
+	 * the end.  Dropping the lock inside the loop would let the "first
+	 * entry on done list" tracking race with ACCEPT/READY on other
+	 * entries.
+	 */
+	tail = READ_ONCE(ring->tail);
+	start = tail;
+	/* Paired with userspace's release store of completion entries. */
+	head = smp_load_acquire(&ring->head);
+
+	/*
+	 * Userspace owns the completion producer index.  If it gets more than a
+	 * ring ahead, the entries are ambiguous; drop the corrupt batch and let
+	 * future eventfd signals drive fresh completions.
+	 */
+	if (head - tail > KVM_APF_RING_SIZE) {
+		tail = head;
+		goto publish_tail;
+	}
+
+	while (tail != head) {
+		struct kvm_async_pf *apf;
+		u64 flags, gpa;
+		u32 idx;
+		gfn_t gfn;
+
+		idx = tail & (KVM_APF_RING_SIZE - 1);
+		gpa = READ_ONCE(ring->entries[idx].gpa);
+		flags = READ_ONCE(ring->entries[idx].flags);
+		tail++;
+
+		/* Completion entries currently support page-aligned GPA only. */
+		if (unlikely(!IS_ALIGNED(gpa, PAGE_SIZE) || flags))
+			continue;
+
+		if (unlikely(clearing))
