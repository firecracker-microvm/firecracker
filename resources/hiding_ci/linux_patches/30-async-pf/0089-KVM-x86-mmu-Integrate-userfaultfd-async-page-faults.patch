From 84300352833928baa3f2d8610fcbc503584f21e3 Mon Sep 17 00:00:00 2001
From: Jack Thomson <jackabt@amazon.com>
Date: Mon, 9 Feb 2026 11:52:30 +0000
Subject: [PATCH 5/8] KVM: x86/mmu: Integrate userfaultfd async page faults

Wire up userfaultfd-based async page faults in x86 MMU:

- Extend kvm_arch_setup_async_pf() with userfault parameter

- In __kvm_mmu_faultin_pfn() on userfault:
  - Check for existing APF, halt if pending acceptance
  - Set up new userfault APF if possible
  - Set KVM_MEMORY_EXIT_FLAG_APF on memory fault exit

Userspace accepts or synchronously completes the APF via KVM_ASYNC_PF_ACCEPT or
KVM_ASYNC_PF_SYNC_COMPLETE ioctls before re-entering the VM.

ACCEPT means userspace will resolve the page asynchronously and call
KVM_ASYNC_PF_READY when done. SYNC_COMPLETE means userspace has already
resolved the fault synchronously (e.g. via UFFDIO_COPY) and the page
is present.

Signed-off-by: Jack Thomson <jackabt@amazon.com>
---
 arch/x86/kvm/mmu/mmu.c | 26 +++++++++++++++++++++++---
 1 file changed, 23 insertions(+), 3 deletions(-)

diff --git a/arch/x86/kvm/mmu/mmu.c b/arch/x86/kvm/mmu/mmu.c
index e82a357e2219..f9a8404fad1b 100644
--- a/arch/x86/kvm/mmu/mmu.c
+++ b/arch/x86/kvm/mmu/mmu.c
@@ -4513,7 +4513,8 @@ static u32 alloc_apf_token(struct kvm_vcpu *vcpu)
 }
 
 static bool kvm_arch_setup_async_pf(struct kvm_vcpu *vcpu,
-				    struct kvm_page_fault *fault)
+				    struct kvm_page_fault *fault,
+				    bool userfault)
 {
 	struct kvm_arch_async_pf arch;
 
@@ -4524,7 +4525,8 @@ static bool kvm_arch_setup_async_pf(struct kvm_vcpu *vcpu,
 	arch.cr3 = kvm_mmu_get_guest_pgd(vcpu, vcpu->arch.mmu);
 
 	return kvm_setup_async_pf(vcpu, fault->addr,
-				  kvm_vcpu_gfn_to_hva(vcpu, fault->gfn), &arch);
+				  kvm_vcpu_gfn_to_hva(vcpu, fault->gfn), &arch,
+				  userfault);
 }
 
 void kvm_arch_async_page_ready(struct kvm_vcpu *vcpu, struct kvm_async_pf *work)
@@ -4598,7 +4600,25 @@ static int __kvm_mmu_faultin_pfn(struct kvm_vcpu *vcpu,
 	if (userfault < 0)
 		return userfault;
 	if (userfault) {
+		bool report_async = false;
+
+		if (!fault->prefetch && kvm_can_do_async_pf(vcpu)) {
+			trace_kvm_try_async_get_page(fault->addr, fault->gfn);
+			if (kvm_async_pf_userfault_exists(vcpu, fault->gfn)) {
+				trace_kvm_async_pf_repeated_fault(fault->addr, fault->gfn);
+				kvm_make_request(KVM_REQ_APF_HALT, vcpu);
+				return RET_PF_RETRY;
+			} else if (kvm_arch_setup_async_pf(vcpu, fault, true)) {
+				report_async = true;
+			}
+		}
+
 		kvm_mmu_prepare_userfault_exit(vcpu, fault);
+
+		if (report_async) {
+			vcpu->run->memory_fault.flags |= KVM_MEMORY_EXIT_FLAG_APF;
+		}
+
 		return -EFAULT;
 	}
 
@@ -4627,7 +4647,7 @@ static int __kvm_mmu_faultin_pfn(struct kvm_vcpu *vcpu,
 			trace_kvm_async_pf_repeated_fault(fault->addr, fault->gfn);
 			kvm_make_request(KVM_REQ_APF_HALT, vcpu);
 			return RET_PF_RETRY;
-		} else if (kvm_arch_setup_async_pf(vcpu, fault)) {
+		} else if (kvm_arch_setup_async_pf(vcpu, fault, false)) {
 			return RET_PF_RETRY;
 		}
 	}
