From 8b4e3665fb9c951cd287122819a3ed35b76ad58d Mon Sep 17 00:00:00 2001
From: Jack Thomson <jackabt@amazon.com>
Date: Fri, 16 Jan 2026 15:14:33 +0000
Subject: [PATCH 4/8] KVM: Add KVM_ASYNC_PF ioctl handler

Add ioctl handler for KVM_ASYNC_PF managing userfaultfd-based async
page faults.

KVM_APF_OP_READY runs without vcpu->mutex in kvm_arch_vcpu_async_ioctl()
as it must be callable from a non-vCPU thread (e.g. a page-resolution
worker).

KVM_APF_OP_ACCEPT and KVM_APF_OP_SYNC_COMPLETE run under vcpu->mutex in
kvm_arch_vcpu_ioctl() as they are called between KVM_RUN exits and must
not race with vCPU execution.

Signed-off-by: Jack Thomson <jackabt@amazon.com>
---
 arch/x86/kvm/Kconfig |  1 +
 arch/x86/kvm/x86.c   | 57 ++++++++++++++++++++++++++++++++++++++++++++
 2 files changed, 58 insertions(+)

diff --git a/arch/x86/kvm/Kconfig b/arch/x86/kvm/Kconfig
index 180781998aa7..b2c8e75c7d6f 100644
--- a/arch/x86/kvm/Kconfig
+++ b/arch/x86/kvm/Kconfig
@@ -30,6 +30,7 @@ config KVM_X86
 	select HAVE_KVM_IRQ_BYPASS
 	select HAVE_KVM_IRQ_ROUTING
 	select HAVE_KVM_READONLY_MEM
+	select HAVE_KVM_VCPU_ASYNC_IOCTL
 	select VHOST_TASK
 	select KVM_ASYNC_PF
 	select USER_RETURN_NOTIFIER
diff --git a/arch/x86/kvm/x86.c b/arch/x86/kvm/x86.c
index a729b8419b61..2689bff82068 100644
--- a/arch/x86/kvm/x86.c
+++ b/arch/x86/kvm/x86.c
@@ -6202,6 +6202,38 @@ static int kvm_get_reg_list(struct kvm_vcpu *vcpu,
 	return 0;
 }
 
+long kvm_arch_vcpu_async_ioctl(struct file *filp, unsigned int ioctl,
+			       unsigned long arg)
+{
+	struct kvm_vcpu *vcpu = filp->private_data;
+	void __user *argp = (void __user *)arg;
+
+	if (ioctl == KVM_ASYNC_PF) {
+		struct kvm_async_pf_req req;
+
+		if (copy_from_user(&req, argp, sizeof(req)))
+			return -EFAULT;
+
+		if (req.flags || req.reserved[0] || req.reserved[1])
+			return -EINVAL;
+
+		if (req.gpa & ~PAGE_MASK)
+			return -EINVAL;
+
+		/*
+		 * Only READY runs without vcpu->mutex — it must be callable
+		 * from a non-vCPU thread.  ACCEPT and SYNC_COMPLETE are
+		 * handled under vcpu->mutex in kvm_arch_vcpu_ioctl().
+		 */
+		if (req.op == KVM_APF_OP_READY)
+			return kvm_async_pf_complete(vcpu, req.gpa);
+
+		return -ENOIOCTLCMD;
+	}
+
+	return -ENOIOCTLCMD;
+}
+
 long kvm_arch_vcpu_ioctl(struct file *filp,
 			 unsigned int ioctl, unsigned long arg)
 {
@@ -6220,6 +6252,31 @@ long kvm_arch_vcpu_ioctl(struct file *filp,
 
 	u.buffer = NULL;
 	switch (ioctl) {
+	case KVM_ASYNC_PF: {
+		struct kvm_async_pf_req req;
+
+		r = -EFAULT;
+		if (copy_from_user(&req, argp, sizeof(req)))
+			goto out;
+
+		r = -EINVAL;
+		if (req.flags || req.reserved[0] || req.reserved[1])
+			goto out;
+		if (req.gpa & ~PAGE_MASK)
+			goto out;
+
+		switch (req.op) {
+		case KVM_APF_OP_ACCEPT:
+			r = kvm_async_pf_accept(vcpu, req.gpa);
+			break;
+		case KVM_APF_OP_SYNC_COMPLETE:
+			r = kvm_async_pf_sync_complete(vcpu, req.gpa);
+			break;
+		default:
+			r = -EINVAL;
+		}
+		break;
+	}
 	case KVM_GET_LAPIC: {
 		r = -EINVAL;
 		if (!lapic_in_kernel(vcpu))
-- 
